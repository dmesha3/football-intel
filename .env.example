#
# Local demo defaults for the Football Intel monorepo.
# Copy these values into the workspace-specific env files, or run:
#   bun run setup:env
#
NODE_ENV=development
DATABASE_URL=postgresql://dev:devpassword@localhost:5432/football_intel
SESSION_SECRET=football-intel-local-session-secret-1234567890
REDIS_URL=redis://localhost:6379
TYPESENSE_API_KEY=football-intel-dev-key
LOG_LEVEL=info
ENABLE_SCRAPING=false
INGESTION_API_URL=http://localhost:3001/api/v1/admin/ingest
MATCH_FIRST_HALF_AUTO_END_MINUTE=50
MATCH_SECOND_HALF_AUTO_END_MINUTE=95
NEXT_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
